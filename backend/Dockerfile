FROM python:3.11-slim

WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Pre-download the tokenizer during build (no PyTorch needed for tokenizer-only)
RUN python -c "from transformers import AutoTokenizer; AutoTokenizer.from_pretrained('sabaridsnfuji/arabic-ai-text-detector')"

COPY . .
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
